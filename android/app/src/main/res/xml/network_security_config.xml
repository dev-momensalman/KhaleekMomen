<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        السماح بـ HTTP للسيرفرات المعروفة للراديو الإسلامي.
        مطلوب على Android 9+ (API 28+) لأن cleartext محظور بالافتراضي.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- mp3quran.net — المصدر الرئيسي للراديو -->
        <domain includeSubdomains="true">live.mp3quran.net</domain>
        <!-- إذاعة القرآن الكريم المصرية الرسمية -->
        <domain includeSubdomains="true">misrquran.gov.eg</domain>
        <domain includeSubdomains="true">holyquranradio.com</domain>
        <!-- RadioJar CDN للبث -->
        <domain includeSubdomains="true">radiojar.com</domain>
        <!-- احتياطي عام للبث -->
        <domain includeSubdomains="true">stream.zeno.fm</domain>
    </domain-config>
</network-security-config>