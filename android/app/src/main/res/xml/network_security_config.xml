<?xml version="1.0" encoding="utf-8"?>
<!--
  FIX: Radio stream URLs use http:// (not https://).
  Android 9+ (API 28+) blocks cleartext HTTP by default.
  This config allows cleartext traffic only for the known radio domains.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- mp3quran.net radio streams use HTTP on custom ports -->
        <domain includeSubdomains="true">mp3quran.net</domain>
        <domain includeSubdomains="true">live.mp3quran.net</domain>
    </domain-config>
</network-security-config>
